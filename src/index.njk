---
layout: base.njk
navActive: home
permalink: /
pageTitle: ""
pageDescription: "Steyning Town Community FC — SCFL Premier champions 2025-26, now in the Pitching-In Isthmian League. 500+ players, 30+ teams. Youth, women's and men's football. Shooting Field, Steyning, West Sussex."
---

<section class="hero" id="home">
  <div class="hero-stripes"></div>
  <div style="position:absolute;inset:0;background:url('https://stcfc.co.uk/wp-content/uploads/2026/05/Isthmian10.jpg') center/cover no-repeat;opacity:.22;pointer-events:none"></div>
  <div class="hero-overlay"></div>
  <div class="hero-slash"></div>
  <div class="hero-slash2"></div>
  <div class="hero-inner">
    <div class="hl">
      <div class="hl-pill">
        <div class="hl-pill-inner"><div class="pdot"></div>Pitching-In Isthmian League · 2026–27</div>
      </div>
      <h1 class="hl-title">Steyning<br><span class="out">Town FC</span></h1>
      <div class="hl-rule"></div>
      <p class="hl-desc">One of <strong>Sussex's oldest clubs</strong>, founded in 1892. Serving Steyning, Bramber, Henfield, Upper Beeding and surrounding West Sussex villages. <strong>SCFL Premier Champions 2025–26</strong> — now back in the Isthmian League with 500+ players across 30+ teams.</p>
      <div class="acts">
        <a href="/join" class="btn-w">Register Now</a>
        <a href="/fixtures" class="btn-o">View Fixtures</a>
      </div>
    </div>
    <div class="hr">
      <div class="hcard">
        <div class="hcard-comp">Pitching-In Isthmian League South East Division</div>
        <div class="hcard-match">Steyning Town FC<br>vs {{ fixtures.upcoming[0].opponent }}</div>
        <div class="hcard-info">{{ fixtures.upcoming[0].date }} · {{ fixtures.upcoming[0].time }}</div>
        <div class="hcard-venue">Shooting Field · Steyning · BN44 3RQ · Admission £10 / £6 concs</div>
      </div>
      <div class="htrophy">
        <div class="htrophy-badge">W</div>
        <div>
          <div class="htrophy-t">SCFL Premier Champions 2025–26</div>
          <div class="htrophy-s">Champions 2023–24 · Peter Bentley Cup 2023–24</div>
        </div>
      </div>
      <div class="hstats">
        <div class="hs"><div class="hs-n">500+</div><div class="hs-l">Players</div></div>
        <div class="hs"><div class="hs-n">30+</div><div class="hs-l">Teams</div></div>
        <div class="hs"><div class="hs-n">★★</div><div class="hs-l">Accredited</div></div>
        <div class="hs"><div class="hs-n">1892</div><div class="hs-l">Founded</div></div>
      </div>
    </div>
  </div>
</section>

<div class="sdiv"></div>
<div class="statb">
  <div class="statb-i">
    <div class="sb2"><div class="sb2-n">134</div><div class="sb2-l">Years of History</div></div>
    <div class="sb2"><div class="sb2-n">500+</div><div class="sb2-l">Registered Players</div></div>
    <div class="sb2"><div class="sb2-n">30+</div><div class="sb2-l">Active Teams</div></div>
    <div class="sb2"><div class="sb2-n">★★</div><div class="sb2-l">England Football</div></div>
  </div>
</div>

<!-- ═══ NEWS ═══ -->
{% set allNews = collections.news %}
{% if allNews.length > 0 %}
<div class="wrap" id="news">
  <div class="sh">
    <div class="sh-top"><div class="sh-r"></div><div class="sh-d"></div></div>
    <div class="sh-bot"><h2 class="sh-t">Latest News</h2><a href="/news" class="sh-m">All News →</a></div>
  </div>
  <div class="news-layout">
    <a href="{{ allNews[0].url }}" class="nfeat">
      <div class="nfeat-img">
        {% if allNews[0].data.image %}<img src="{{ allNews[0].data.image }}" alt="{{ allNews[0].data.imageAlt or allNews[0].data.title }}">{% endif %}
      </div>
      <div class="nfeat-body">
        <div class="ntag">{{ allNews[0].data.category or "Club News" }}</div>
        <h3 class="ntitle">{{ allNews[0].data.title }}</h3>
        <p class="nbody">{{ allNews[0].data.summary }}</p>
        <div class="ndate">{{ allNews[0].date | dateDisplay }}</div>
      </div>
    </a>
    <div class="nside">
      {% for post in allNews | slice(1, 4) %}
      <a href="{{ post.url }}" class="nsm">
        <div class="nsm-img">{% if post.data.image %}<img src="{{ post.data.image }}" alt="{{ post.data.imageAlt or post.data.title }}">{% endif %}</div>
        <div class="nsm-body">
          <div class="ntag">{{ post.data.category or "Club News" }}</div>
          <div class="nsm-title">{{ post.data.title }}</div>
          <div class="nsm-date">{{ post.date | dateDisplay }}</div>
        </div>
      </a>
      {% endfor %}
    </div>
  </div>
</div>
{% endif %}

<!-- ═══ FIXTURES & RESULTS ═══ -->
<div class="wrap" id="fixtures" style="padding-top:0">
  <div class="fx-results-grid">
    <div>
      <div class="sh" style="margin-bottom:1rem">
        <div class="sh-top"><div class="sh-r"></div><div class="sh-d"></div></div>
        <div class="sh-bot"><h2 class="sh-t">Upcoming Fixtures</h2><a href="/fixtures" class="sh-m">Full Schedule →</a></div>
      </div>
      <div class="fbox">
        <div class="fhd"><div>Home</div><div class="c">Date · KO</div><div class="r">Away</div></div>
        {% for f in fixtures.upcoming | slice(0, 4) %}
        <div class="fr">
          {% if f.location == "h" %}
          <div class="fteam stcfc">Steyning Town</div>
          <div class="fmid"><div class="fvs">vs</div><div class="fdate">{{ f.date }} · {{ f.time }}</div><div><span class="floc h">Home</span></div><div class="fcomp">{{ f.competition }}</div></div>
          <div class="fteam r">{{ f.opponent }}</div>
          {% else %}
          <div class="fteam">{{ f.opponent }}</div>
          <div class="fmid"><div class="fvs">vs</div><div class="fdate">{{ f.date }} · {{ f.time }}</div><div><span class="floc a">Away</span></div><div class="fcomp">{{ f.competition }}</div></div>
          <div class="fteam r stcfc">Steyning Town</div>
          {% endif %}
        </div>
        {% endfor %}
      </div>
      <div class="adm-note">
        <div class="adm-item">Adults <span>£10</span></div>
        <div class="adm-sep"></div>
        <div class="adm-item">Concessions <span>£6</span></div>
        <div class="adm-sep"></div>
        <div class="adm-item">Under 16s <span>Free</span></div>
        <div class="adm-sep"></div>
        <div class="adm-item" style="color:var(--muted);font-size:9.5px">Women's: £3 all · U16s free</div>
      </div>
    </div>
    <div>
      <div class="sh" style="margin-bottom:1rem">
        <div class="sh-top"><div class="sh-r"></div><div class="sh-d"></div></div>
        <div class="sh-bot"><h2 class="sh-t">Recent Results</h2><a href="/fixtures" class="sh-m">All Results →</a></div>
      </div>
      <div class="fbox">
        <div class="fhd"><div>Home</div><div class="c">Score</div><div class="r">Away</div></div>
        {% for r in fixtures.results | slice(0, 4) %}
        <div class="fr">
          {% if r.location == "h" %}
          <div class="fteam stcfc">Steyning Town</div>
          <div class="fmid"><div class="fscore">{{ r.steyningScore }}–{{ r.opponentScore }}</div><div class="fres {{ r.result }}">{% if r.result == "w" %}Win{% elif r.result == "d" %}Draw{% else %}Loss{% endif %}</div><div class="fcomp">{{ r.date }} · {{ r.competition }}</div></div>
          <div class="fteam r">{{ r.opponent }}</div>
          {% else %}
          <div class="fteam">{{ r.opponent }}</div>
          <div class="fmid"><div class="fscore">{{ r.opponentScore }}–{{ r.steyningScore }}</div><div class="fres {{ r.result }}">{% if r.result == "w" %}Win{% elif r.result == "d" %}Draw{% else %}Loss{% endif %}</div><div class="fcomp">{{ r.date }} · {{ r.competition }}</div></div>
          <div class="fteam r stcfc">Steyning Town</div>
          {% endif %}
        </div>
        {% endfor %}
      </div>
    </div>
  </div>
</div>

<!-- ═══ HISTORY ═══ -->
<div class="history">
  <div class="history-inner">
    <div class="h-sup">Est. 1892</div>
    <h2 class="h-head">Our History</h2>
    <div class="timeline">
      <div class="tl"><div class="tl-year">1892</div><div class="tl-t">Club Founded</div><div class="tl-b">Established as "Steyning" — one of Sussex's oldest football clubs.</div></div>
      <div class="tl"><div class="tl-year">1896</div><div class="tl-t">West Sussex League</div><div class="tl-b">Became a founding member of the West Sussex Football League.</div></div>
      <div class="tl"><div class="tl-year">1979</div><div class="tl-t">Renamed</div><div class="tl-b">Officially became Steyning Town Football Club.</div></div>
      <div class="tl"><div class="tl-year">1984–86</div><div class="tl-t">Golden Era</div><div class="tl-b">Won Division One title, the Sussex Senior Cup twice and reached the FA Vase quarter-finals.</div></div>
      <div class="tl"><div class="tl-year">2013</div><div class="tl-t">Community Club</div><div class="tl-b">Merged with Steyning Strikers to become Steyning Town Community FC, growing to 18+ teams.</div></div>
      <div class="tl"><div class="tl-year">2015</div><div class="tl-t">3G Pitch Opened</div><div class="tl-b">£450,000 all-weather pitch at Shooting Field — funded by the Wilson Trust, HSBC and The Hub.</div></div>
      <div class="tl"><div class="tl-year">2016–17</div><div class="tl-t">Club of the Year</div><div class="tl-b">Won the Sussex FA Community Club of the Year award back-to-back.</div></div>
      <div class="tl"><div class="tl-year">2018</div><div class="tl-t">Women's Team</div><div class="tl-b">Established the Women's First Team, now competing in the London &amp; South East Regional WFL.</div></div>
      <div class="tl"><div class="tl-year">2023–24</div><div class="tl-t">First Promotion</div><div class="tl-b">SCFL Premier champions and Peter Bentley Cup winners. First ever Isthmian League promotion.</div></div>
      <div class="tl"><div class="tl-year">2025–26</div><div class="tl-t">Champions Again</div><div class="tl-b">Returned to and won the SCFL Premier for a second time. Back in the Isthmian League.</div></div>
    </div>
  </div>
</div>

<!-- ═══ HONOURS ═══ -->
<div class="ach">
  <div class="ach-inner">
    <div class="ach-sup">Club Honours</div>
    <h2 class="ach-h">A History<br>Of Success</h2>
    <div class="ach-grid">
      <div class="ac"><div class="ac-i">I</div><div class="ac-t">SCFL Premier Champions</div><div class="ac-b">2023–24 &amp; 2025–26. Promoted to the Isthmian League both times.</div></div>
      <div class="ac"><div class="ac-i">II</div><div class="ac-t">Sussex Senior Cup</div><div class="ac-b">Winners in 1985–86 &amp; 1988–89. Sussex County League Div 2 champions 1977–78.</div></div>
      <div class="ac"><div class="ac-i">III</div><div class="ac-t">Community Club of the Year</div><div class="ac-b">Sussex FA award 2016 &amp; 2017. 2-Star England Football accreditation.</div></div>
      <div class="ac"><div class="ac-i">IV</div><div class="ac-t">Women's Double 2022–23</div><div class="ac-b">SECWFL Division One West champions and League Cup winners.</div></div>
      <div class="ac"><div class="ac-i">V</div><div class="ac-t">FA Vase Quarter-Finals</div><div class="ac-b">Reached the last eight in 1984–85 — the club's best run in the competition.</div></div>
      <div class="ac"><div class="ac-i">VI</div><div class="ac-t">Peter Bentley Cup 2023–24</div><div class="ac-b">Won the cup in the same season as the SCFL Premier title — a memorable double.</div></div>
    </div>
  </div>
</div>

<!-- ═══ SQUAD ═══ -->
<div class="squad" id="squad">
  <div class="squad-inner">
    <div class="sh">
      <div class="sh-top"><div class="sh-r"></div><div class="sh-d"></div></div>
      <div class="sh-bot"><h2 class="sh-t">Management &amp; Squad</h2><a href="/squad" class="sh-m">Full Squad →</a></div>
    </div>
    <div class="mgmt-row">
      <div class="mgmt-card">
        <div class="mgmt-avatar"><span>BO</span></div>
        <div>
          <div class="mgmt-role">Men's First Team Manager</div>
          <div class="mgmt-name">Brannon O'Neill</div>
          <div class="mgmt-desc">Appointed May 2026 · 740+ non-league appearances</div>
        </div>
      </div>
      <div class="mgmt-card">
        <div class="mgmt-avatar"><span>KB</span></div>
        <div>
          <div class="mgmt-role">Women's First Team Manager</div>
          <div class="mgmt-name">Kaz Bridgewater</div>
          <div class="mgmt-desc">Returned June 2026 · Former STCFC manager</div>
        </div>
      </div>
    </div>
    <div style="background:#fff;border:1px solid var(--border);border-radius:10px;padding:2rem;border-left:4px solid var(--red);display:flex;align-items:center;gap:1.25rem">
      <div style="width:3px;min-height:36px;background:var(--red);border-radius:2px;flex-shrink:0;align-self:stretch"></div>
      <div>
        <div style="font-family:'Montserrat';font-size:9px;font-weight:800;letter-spacing:2px;text-transform:uppercase;color:var(--red);margin-bottom:.375rem">2026–27 Season</div>
        <div style="font-family:'Montserrat';font-size:1rem;font-weight:900;text-transform:uppercase;color:var(--text);margin-bottom:.35rem">Squad Announcement Coming Pre-Season</div>
        <div style="font-size:13.5px;color:var(--muted);font-style:italic">Full player profiles to be confirmed ahead of the Isthmian League campaign. <a href="/squad" style="color:var(--red);text-decoration:none">View the squad page →</a></div>
      </div>
    </div>
  </div>
</div>

<!-- ═══ TEAMS ═══ -->
<div class="teams" id="teams">
  <div class="teams-inner">
    <div class="sh">
      <div class="sh-top"><div class="sh-r"></div><div class="sh-d"></div></div>
      <div class="sh-bot"><h2 class="sh-t">A Team For Everyone</h2></div>
    </div>
    <p class="sh-sub">Over 500 registered players across 30+ teams — from Mini-Kickers to Veterans. Every registered player receives a full playing strip.</p>
    <div class="tg">
      <div class="tc"><div class="tc-n">Men's First Team</div><div class="tc-l">Pitching-In Isthmian League South East</div></div>
      <div class="tc"><div class="tc-n">Men's Reserves</div><div class="tc-l">SCFL Division One</div></div>
      <div class="tc"><div class="tc-n">Women's First Team</div><div class="tc-l">London &amp; South East Regional WFL</div></div>
      <div class="tc"><div class="tc-n">Women's Development</div><div class="tc-l">Sussex County Women's League</div></div>
      <div class="tc"><div class="tc-n">U18s Male</div><div class="tc-l">Isthmian U18s League (first time)</div></div>
      <div class="tc"><div class="tc-n">U18s Female</div><div class="tc-l">SCFL Youth League</div></div>
      <div class="tc"><div class="tc-n">Mixed Youth (15 teams)</div><div class="tc-l">Horsham &amp; District Youth FL · Saturdays</div></div>
      <div class="tc"><div class="tc-n">Girls Teams (6 squads)</div><div class="tc-l">Sussex County Women &amp; Girls FL · Sundays</div></div>
      <div class="tc"><div class="tc-n">Veterans (2 squads)</div><div class="tc-l">Sussex Sunday Football League</div></div>
      <div class="tc"><div class="tc-n">Development Centre</div><div class="tc-l">Ages 3–15 · After-school · £10/session</div></div>
      <div class="tc"><div class="tc-n">Mini-Kickers</div><div class="tc-l">Training only · All welcome</div></div>
      <div class="tc"><div class="tc-n">Tournament '26</div><div class="tc-l">Grassroots youth · June 2026</div></div>
    </div>
  </div>
</div>

<!-- ═══ GROUND ═══ -->
<div class="ground" id="ground">
  <div class="ground-inner">
    <div class="ground-grid">
      <div>
        <div class="g-sup">The Peter Humphreys Memorial Ground</div>
        <h2 class="g-h">Shooting Field,<br>Steyning</h2>
        <div class="g-rule"></div>
        <p class="g-body">Home to Steyning Town FC for generations. A £450,000 3G all-weather pitch, funded by the Wilson Memorial Trust, HSBC and The Hub, opened in October 2015. The pitch is maintained twice weekly and independently tested to maintain full FA and FIFA accreditation.</p>
        <div class="g-addr">Shooting Field · Steyning · West Sussex · BN44 3RQ</div>
        <div class="ground-imgs">
          <img src="https://stcfc.co.uk/wp-content/uploads/2025/11/PitchHire.jpg" alt="Shooting Field 3G Pitch">
          <img src="https://stcfc.co.uk/wp-content/uploads/2023/08/ch1.jpg" alt="STCFC Clubhouse">
          <img src="https://stcfc.co.uk/wp-content/uploads/2023/03/Clubhouse1.jpg" alt="STCFC Clubhouse Interior">
        </div>
        <div class="clubhouse-hl">The Clubhouse</div>
        <div class="ch-items">
          <div class="ch-item"><strong>Bar</strong>Local ales, lager, wine, soft drinks &amp; coffee</div>
          <div class="ch-item"><strong>Hire</strong>Available for private functions &amp; events</div>
          <div class="ch-item"><strong>Children's Parties</strong>3G pitch + party tea available</div>
          <div class="ch-item"><strong>Contact</strong>theclubhouse.steyning@gmail.com</div>
        </div>
      </div>
      <div class="gfs">
        <div class="gf"><div class="gf-mark"></div><div><div class="gf-t">3G All-Weather Pitch</div><div class="gf-s">£450,000 · Opened October 2015 · FA &amp; FIFA accredited</div></div></div>
        <div class="gf"><div class="gf-mark"></div><div><div class="gf-t">Floodlit Main Pitch</div><div class="gf-s">All training takes place on the main floodlit pitch at Shooting Field</div></div></div>
        <div class="gf"><div class="gf-mark"></div><div><div class="gf-t">Refurbished Clubhouse</div><div class="gf-s">Updated changing rooms, medical facilities &amp; bar</div></div></div>
        <div class="gf"><div class="gf-mark"></div><div><div class="gf-t">Heart of Steyning</div><div class="gf-s">Accessible from A283 · Free parking available</div></div></div>
        <div class="gf"><div class="gf-mark"></div><div><div class="gf-t">★★ England Football Accredited</div><div class="gf-s">Highest community club standard in English football</div></div></div>
        <div class="gf"><div class="gf-mark"></div><div><div class="gf-t">Pitch Hire Available</div><div class="gf-s">Weekday &amp; summer slots · Contact Gerry for details</div></div></div>
      </div>
    </div>
  </div>
</div>

<!-- ═══ SHOP ═══ -->
<div class="shop" id="shop">
  <div class="shop-inner">
    <div class="sh">
      <div class="sh-top"><div class="sh-r"></div><div class="sh-d"></div></div>
      <div class="sh-bot"><h2 class="sh-t">Club Shop</h2><a href="/shop" class="sh-m">View All →</a></div>
