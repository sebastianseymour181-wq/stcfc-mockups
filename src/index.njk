<!-- ═══ SPONSORS ═══ -->
<div class="sp">
  <div class="sp-inner">
    <div class="sp-l">Club Partners 2025–26</div>
    <p class="sp-s">Proudly supported by local and regional businesses across West Sussex · <a href="/sponsors" style="color:var(--red);text-decoration:none">View all partners →</a></p>
    <div class="sp-tier">
      <div class="sp-tl">Elite Sponsors</div>
      <div style="display:grid;grid-template-columns:repeat(5,1fr);gap:.75rem">
        {% for s in sponsors.elite %}
        <div style="background:#fff;border:1px solid var(--border);border-radius:8px;padding:.75rem;display:flex;align-items:center;justify-content:center;aspect-ratio:2/1">
          <img src="{{ s.logo }}" alt="{{ s.name }}" style="max-width:100%;max-height:52px;object-fit:contain" loading="lazy">
        </div>
        {% endfor %}
      </div>
    </div>
    <div class="sp-tier">
      <div class="sp-tl">Kit Partner</div>
      <div style="display:inline-flex;background:#fff;border:1px solid rgba(194,16,32,.25);border-radius:8px;padding:.75rem 1.5rem;align-items:center;gap:1rem">
        <img src="https://stcfc.co.uk/wp-content/uploads/2025/05/Edge-Teamwear-Logo-Large.png" alt="Edge Teamwear" style="height:36px;object-fit:contain" loading="lazy">
        <span style="font-family:'Montserrat';font-size:9px;font-weight:800;letter-spacing:1.5px;text-transform:uppercase;color:var(--red)">Official Kit Partner</span>
      </div>
    </div>
    <div class="sp-tier">
      <div class="sp-tl">Club Sponsors</div>
      <div class="sp-grid">
        {% for s in sponsors.club %}
        <div class="sp-item">{{ s.name }}</div>
        {% endfor %}
      </div>
    </div>
  </div>
</div>

<!-- ═══ FAQ ═══ -->
<div class="faq" id="faq">
  <div class="faq-inner">
    <div class="sh">
      <div class="sh-top"><div class="sh-r"></div><div class="sh-d"></div></div>
      <div class="sh-bot"><h2 class="sh-t">Frequently Asked Questions</h2></div>
    </div>
